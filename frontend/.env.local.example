# ─── Supabase ───────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Anthropic Claude API ───────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── ML Service ─────────────────────────────────────────
# Local development: http://localhost:8000
# Production (Railway): https://your-ml-service.railway.app
ML_SERVICE_URL=http://localhost:8000

# ─── Admin ──────────────────────────────────────────────
# Password for Dr. Dedhia's admin dashboard
ADMIN_PASSWORD=dedhia2024

# ─── Twilio WhatsApp (optional for MVP) ─────────────────
# Get from: twilio.com → Console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
